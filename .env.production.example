# ═══════════════════════════════════════
#  HookRelay — Production Configuration
# ═══════════════════════════════════════
#  ⚠️ Copy this to .env.production and fill in your secrets
#  This file IS committed to GitHub for reference.

# ── Application ──
APP_ENV=production
PORT=3000
RUST_LOG=info,hookrelay=debug

# ── Database (Neon) ──
DATABASE_URL=

# ── Redis (Upstash) ──
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Security (⚠️ Generate with: openssl rand -hex 32) ──
HMAC_SECRET=
JWT_SECRET=

# ── Data Retention ──
RETENTION_DAYS=7

# ── CORS ──
CORS_ORIGINS=https://dashboard-ochre-kappa-99.vercel.app,https://dashboard.hookrelay.io

# ── App URL ──
APP_URL=https://dashboard.hookrelay.io

# ── Stripe (legacy) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ── Polar.sh ✅ CONFIGURED ──
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_PRO=79fee3f9-04a2-46c1-804e-8ca7542b8119
POLAR_PRODUCT_BUSINESS=e5b7d88a-7606-4963-a070-4102ca6405e2
POLAR_ENV=production

# ── iyzico ⏳ PENDING ──
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_ENV=sandbox
IYZICO_PRICE_PRO=14900
IYZICO_PRICE_BUSINESS=44900

# ── Email (Resend) ⏳ PENDING ──
RESEND_API_KEY=
NOTIFY_EMAIL=
NOTIFY_EMAIL_FROM=

# ── Storage (Cloudflare R2) ⏳ PENDING ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hookrelay-storage
R2_ENDPOINT=

# ── Monitoring (Grafana Cloud) ⏳ PENDING ──
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ── Outbound IPs (for customer firewall whitelisting) ──
OUTBOUND_IPS=

# ── Logging ──
LOG_FORMAT=json
