# ═══════════════════════════════════════
#  HookSniff — Production Configuration
# ═══════════════════════════════════════
#  ⚠️ Copy this to .env.production and fill in your secrets
#  This file IS committed to GitHub for reference.

# ── Application ──
APP_ENV=production
PORT=3000
RUST_LOG=info,hooksniff=debug

# ── Database (Neon) ──
DATABASE_URL=

# ── Redis (Upstash) ──
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Set to "redis" to use Redis for rate limiting (recommended for production)
RATE_LIMIT_STORE=memory

# ── Security (⚠️ Generate with: openssl rand -hex 32) ──
HMAC_SECRET=
JWT_SECRET=

# ── Data Retention ──
RETENTION_DAYS=7

# ── CORS ──
CORS_ORIGINS=https://hooksniff.vercel.app

# ── App URL ──
APP_URL=https://hooksniff.vercel.app

# ── Stripe (legacy) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ── Polar.sh ✅ CONFIGURED ──
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_PRO=ec5826ad-4a01-4146-b2d0-3b99eaf150a5
POLAR_PRODUCT_BUSINESS=e5b7d88a-7606-4963-a070-4102ca6405e2
POLAR_ENV=production

# ── iyzico ⏳ PENDING ──
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_ENV=sandbox
IYZICO_PRICE_PRO=14900
IYZICO_PRICE_BUSINESS=44900

# ── Email (Gmail API via GCP Service Account) ──
NOTIFY_EMAIL=
NOTIFY_FROM_EMAIL=noreply@hooksniff.vercel.app
EMAIL_BASE_URL=https://hooksniff.vercel.app

# ── Push Notifications (Firebase Cloud Messaging) ──
FCM_SERVER_KEY=

# ── Storage (Cloudflare R2) ⏳ PENDING ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hooksniff-storage
R2_ENDPOINT=

# ── Monitoring (Grafana Cloud) ──
# Set OTEL_ENABLED=true to enable distributed tracing
# Stack: hookrelay (ID: 1625476), Region: prod-eu-west-2
# Auth: Basic base64(1625476:<glc_token>)
# Token yenileme: https://grafana.com/orgs/hookrelay → Security → Cloud Access Policies → hooksniff
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic MTYyNTQ3NjpnbGNfZXlKdklqb2lNVGMxTnpNek5TSXNJbTRpT2lKb2IyOXJjMjVwWm1ZdGFHOXZhM0psYkdGNUlpd2lheUk2SWpoQk1FTllOVE54YUdOME56WlBNVXhGVURnNWFVUXhRaUlzSW0waU9uc2ljaUk2SW5WekluMTk=

# ── Outbound IPs (for customer firewall whitelisting) ──
OUTBOUND_IPS=

# ── Logging ──
LOG_FORMAT=json

# ── Webhook Limits ──
# Maximum webhook payload size in bytes (default: 1MB)
MAX_PAYLOAD_BYTES=1048576
# Webhook payload format: "json" or "raw" (default: json)
WEBHOOK_FORMAT=standard
# Timestamp tolerance for webhook signature verification in seconds (default: 300)
WEBHOOK_TIMESTAMP_TOLERANCE_SECS=300
