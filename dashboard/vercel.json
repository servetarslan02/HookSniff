{
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "https://hooksniff-api-499907444852.europe-west1.run.app/v1/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
