# HookSniff Dashboard — Environment Variables
# Copy to .env.local for local development

# API URL (without /v1 suffix)
NEXT_PUBLIC_API_URL=http://localhost:3000/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3000/v1/ws

# Site URL (for SEO/OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Version (auto-filled by CI)
NEXT_PUBLIC_VERSION=0.1.0

# Upstash Redis (for playground feature)
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
