{
  "name": "hooksniff-dashboard",
  "version": "0.4.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build && node -e \"const fs=require('fs');const p='.next/server/app/[locale]/(dashboard)/page_client-reference-manifest.js';if(!fs.existsSync(p)){console.log('[postbuild] Creating missing manifest:',p);fs.mkdirSync(require('path').dirname(p),{recursive:true});fs.writeFileSync(p,'module.exports={id:{},name:{},chunks:{}}');}\"",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test --config=playwright.config.ts",
    "test:visual:update": "playwright test --config=playwright.config.ts --update-snapshots"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@sentry/nextjs": "^10.53.1",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-virtual": "^3.13.24",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.1.6",
    "next": "^15.5.15",
    "next-intl": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@axe-core/react": "^4.9.0",
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^15.0.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/forms": "^0.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react": "^7.37.5",
    "jest-axe": "^8.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.5"
  }
}
