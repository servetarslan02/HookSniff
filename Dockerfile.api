FROM rust:1.82-slim AS builder

WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY api/ api/
COPY worker/ worker/

RUN cargo build --release -p hookrelay-api

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/hookrelay-api /usr/local/bin/
EXPOSE 3000

CMD ["hookrelay-api"]
