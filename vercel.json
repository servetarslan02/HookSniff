{
  "buildCommand": "cd dashboard && rm -rf .next && npm ci && npm run build",
  "outputDirectory": "dashboard/.next",
  "framework": "nextjs",
  "installCommand": "cd dashboard && npm ci",
  "ignoreCommand": "git diff --quiet HEAD~1 HEAD -- dashboard/ api/ vercel.json package.json worker/ common/ || exit 1",
  "rewrites": [
    { "source": "/api/health", "destination": "https://hooksniff-api-cec4.onrender.com/health" },
    { "source": "/api/v1/:path*", "destination": "https://hooksniff-api-cec4.onrender.com/v1/:path*" },
    { "source": "/api/:path*", "destination": "https://hooksniff-api-cec4.onrender.com/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/.env",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}

