{
  "buildCommand": "cd dashboard && npm ci && npm run build && node fix-manifests.js",
  "outputDirectory": "dashboard/.next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/health", "destination": "https://hooksniff-api-1046140057667.europe-west1.run.app/health" },
    { "source": "/api/:path*", "destination": "https://hooksniff-api-1046140057667.europe-west1.run.app/v1/:path*" }
  ]
}

