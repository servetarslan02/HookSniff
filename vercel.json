{
  "buildCommand": "npm ci && npm run build && node -e \"const fs=require('fs');const p='.next/server/app/[locale]/(dashboard)/page_client-reference-manifest.js';if(!fs.existsSync(p)){console.log('Creating missing manifest:',p);fs.mkdirSync(require('path').dirname(p),{recursive:true});fs.writeFileSync(p,'module.exports={id:{},name:{},chunks:{}}');}\"",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "rewrites": [
    { "source": "/api/health", "destination": "https://hooksniff-api-1046140057667.europe-west1.run.app/health" },
    { "source": "/api/newsletter", "destination": "/api/newsletter" },
    { "source": "/api/status", "destination": "/api/status" },
    { "source": "/api/playground/in/:id", "destination": "/api/playground/in/:id" },
    { "source": "/api/playground/history/:id", "destination": "/api/playground/history/:id" },
    { "source": "/api/playground/token", "destination": "/api/playground/token" },
    { "source": "/api/:path*", "destination": "https://hooksniff-api-1046140057667.europe-west1.run.app/v1/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/.env",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}

