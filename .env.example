# HookRelay Configuration
# ========================
# Copy this file to .env and fill in your values.
# Generate secrets with: openssl rand -hex 32

# ── Server ──
PORT=3000
APP_ENV=development

# ── Database (PostgreSQL) ──
# For local dev with Docker: postgresql://hookrelay:hookrelay_local@localhost:5432/hookrelay?sslmode=disable
# For production (Neon/Supabase/etc): postgresql://user:pass@host:5432/db?sslmode=require
DATABASE_URL=postgresql://hookrelay:hookrelay_local@localhost:5432/hookrelay?sslmode=disable

# ── Security ──
# ⚠️ Generate with: openssl rand -hex 32
# Never use placeholder or empty values in production!
HMAC_SECRET=
JWT_SECRET=

# ── Rate Limiting ──
MAX_PAYLOAD_BYTES=1048576

# ── Data Retention (days) ──
RETENTION_DAYS=30

# ── Webhook Format ──
WEBHOOK_FORMAT=standard        # standard | cloudevents
WEBHOOK_TIMESTAMP_TOLERANCE_SECS=300

# ── CORS (production only, comma-separated) ──
# CORS_ORIGINS=https://dashboard.hookrelay.io,https://hookrelay.io

# ── OpenTelemetry (optional) ──
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_FORMAT=pretty              # pretty | json

# ── Stripe Billing (optional — disabled if not set) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ── App URL (for Stripe redirects) ──
APP_URL=http://localhost:3001

# ── Optional: Notifications ──
# Uncomment and configure if you want delivery failure alerts.
# SLACK_WEBHOOK_URL=
# SENDGRID_API_KEY=
# NOTIFY_EMAIL=admin@example.com
# NOTIFY_EMAIL_FROM=noreply@hookrelay.dev
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
