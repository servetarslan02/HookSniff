# HookRelay Configuration

# Server
PORT=3000
APP_ENV=development

# CORS (comma-separated origins, used in production)
# CORS_ORIGINS=https://dashboard.hookrelay.io,https://hookrelay.io

# Database (PostgreSQL)
DATABASE_URL=postgresql://hookrelay:hookrelay_local@localhost:5432/hookrelay?sslmode=disable

# Security
# Generate secrets with: openssl rand -hex 32
# Never use placeholder values in production!
HMAC_SECRET=
JWT_SECRET=

# Rate Limiting
MAX_PAYLOAD_BYTES=1048576

# Worker
# max_attempts is now per-endpoint (configured via retry_policy in endpoint settings)

# Queue (PostgreSQL-based — uses webhook_queue table)
# No external queue service needed

# Data Retention (days)
RETENTION_DAYS=30

# AI Center
AI_CHECK_INTERVAL_SECS=30
AI_RISK_THRESHOLD_WARNING=60
AI_RISK_THRESHOLD_CRITICAL=80
AI_AUTO_FIX_ENABLED=true
AI_DEFENSE_ENABLED=true
AI_MAX_AUTO_ACTIONS_PER_HOUR=20

# AI Model API Keys (opsiyonel — biri veya ikisi de olabilir)
# MiMo: https://mimo.xiaomi.com → Log analizi, anomali tespiti
MIMO_API_KEY=your-mimo-api-key-here
# OpenAI: https://platform.openai.com/api-keys → Kod inceleme, fix önerisi
OPENAI_API_KEY=your-openai-api-key-here
# Gemini: https://aistudio.google.com/apikey → Genel analiz, log analizi, rapor
GEMINI_API_KEY=your-gemini-api-key-here
# Groq: https://console.groq.com/keys → Genel analiz, kod inceleme (hızlı)
GROQ_API_KEY=your-groq-api-key-here
# Cerebras: https://cloud.cerebras.ai/ → Genel analiz, log analizi (hızlı)
CEREBRAS_API_KEY=your-cerebras-api-key-here
# OpenRouter: https://openrouter.ai/keys → Tüm yetenekler (çoklu model erişimi)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Event Format
WEBHOOK_FORMAT=standard  # standard | cloudevents

# Replay Protection
WEBHOOK_TIMESTAMP_TOLERANCE_SECS=300

# Bildirim Kanalları (opsiyonel)
# Slack: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=your-slack-webhook-url-here
# Email (SendGrid): https://sendgrid.com
SENDGRID_API_KEY=your-sendgrid-api-key-here
NOTIFY_EMAIL=admin@example.com
NOTIFY_EMAIL_FROM=ai@hookrelay.dev
# Email (SMTP) — SendGrid yoksa bunu kullan
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_FORMAT=pretty

# ── Stripe (optional — billing disabled if not set) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ── App URL (for Stripe redirects) ──
APP_URL=http://localhost:3001
