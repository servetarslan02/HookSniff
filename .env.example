# HookSniff Configuration
# ========================
# Copy this file to .env and fill in your values.
# Generate secrets with: openssl rand -hex 32

# ── Server ──
PORT=3000
APP_ENV=development

# ── Database (PostgreSQL) ──
# For local dev with Docker: postgresql://hooksniff:hooksniff_local@localhost:5432/hooksniff?sslmode=disable
# For production (Neon/Supabase/etc): postgresql://user:pass@host:5432/db?sslmode=require
DATABASE_URL=postgresql://hooksniff:hooksniff_local@localhost:5432/hooksniff?sslmode=disable

# ── Security ──
# ⚠️ Generate with: openssl rand -hex 32
# Never use placeholder or empty values in production!
HMAC_SECRET=
JWT_SECRET=

# ── Rate Limiting ──
MAX_PAYLOAD_BYTES=1048576

# ── Data Retention (days) ──
RETENTION_DAYS=30

# ── Webhook Format ──
WEBHOOK_FORMAT=standard        # standard | cloudevents
WEBHOOK_TIMESTAMP_TOLERANCE_SECS=300

# ── CORS (production only, comma-separated) ──
# CORS_ORIGINS=https://hooksniff.is-a.dev,https://hooksniff.is-a.dev

# ── OpenTelemetry (optional) ──
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_HEADERS=
LOG_FORMAT=pretty              # pretty | json

# ── Outbound IPs (for customer firewall whitelisting) ──
# Comma-separated list of static IPs that HookSniff uses to deliver webhooks.
# Enterprise customers whitelist these in their firewalls/WAFs.
OUTBOUND_IPS=

# ── Redis (Upstash — optional, for rate limiting & dedup) ──
# For local dev with Docker: redis://localhost:6379
# For production (Upstash): rediss://default:TOKEN@xxx.upstash.io:6379
REDIS_URL=
# Upstash REST API (recommended for serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Stripe Billing (optional — disabled if not set) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ── Polar.sh Billing (optional — MoR, handles tax/invoicing) ──
# Get access token: https://polar.sh → Settings → Access Tokens
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_PRO=79fee3f9-04a2-46c1-804e-8ca7542b8119
POLAR_PRODUCT_BUSINESS=e5b7d88a-7606-4963-a070-4102ca6405e2
POLAR_ENV=sandbox            # sandbox | production

# ── iyzico Billing (optional — Turkish payments, TRY) ──
# Get credentials: https://merchant.iyzipay.com → API Keys
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_ENV=sandbox            # sandbox | production
IYZICO_PRICE_PRO=14900        # ₺149.00 in kuruş
IYZICO_PRICE_BUSINESS=44900   # ₺449.00 in kuruş

# ── App URL (for Stripe redirects) ──
APP_URL=http://localhost:3001

# ── Email — Resend (optional) ──
# Get API key: https://resend.com → API Keys
RESEND_API_KEY=
NOTIFY_EMAIL=admin@example.com
NOTIFY_FROM_EMAIL=noreply@hooksniff.is-a.dev

# ── Storage — Cloudflare R2 (optional) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hooksniff-storage
R2_ENDPOINT=

# ── Optional: Legacy SMTP (use Resend instead) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
