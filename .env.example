# HookRelay Configuration

# Server
PORT=3000

# Database (CockroachDB)
DATABASE_URL=postgresql://root@localhost:26257/hookrelay?sslmode=disable

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=webhook-deliveries
KAFKA_CONSUMER_GROUP=hookrelay-worker

# Security
HMAC_SECRET=change-me-in-production
JWT_SECRET=change-me-jwt-secret-in-production

# Rate Limiting
MAX_PAYLOAD_BYTES=1048576

# Worker
MAX_ATTEMPTS=3

# Data Retention (days)
RETENTION_DAYS=30
