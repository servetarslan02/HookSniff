# Hookrelay Environment Configuration
# Copy to .env and adjust values

# API
PORT=3000
MAX_PAYLOAD_BYTES=1048576

# Database (CockroachDB)
DATABASE_URL=postgresql://root@localhost:26257/hookrelay?sslmode=disable

# Kafka / Redpanda
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=webhook-deliveries
KAFKA_CONSUMER_GROUP=hookrelay-worker

# Security
HMAC_SECRET=change-me-to-a-random-string

# Worker
MAX_ATTEMPTS=3
