# Item 347: This root .dockerignore covers all services (api, worker, dashboard)
# since all Dockerfiles use the root as build context. No per-service
# .dockerignore files are needed.
.git
.github.ai-contexttarget/
dashboard/node_modules/
dashboard/.next/
dashboard/.turbo/
*.md
!README.md
.env*
!.env.example
monitoring/
tests/
scripts/
landing/
k8s/
*.ps1
*.sh
!entrypoint-api.sh
.gitignore
.DS_Store
