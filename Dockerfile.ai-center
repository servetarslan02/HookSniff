FROM rust:latest AS builder

WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY api/ api/
COPY worker/ worker/
COPY ai-center/ ai-center/

RUN cargo build --release -p hookrelay-ai-center

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/hookrelay-ai-center /usr/local/bin/

CMD ["hookrelay-ai-center"]
