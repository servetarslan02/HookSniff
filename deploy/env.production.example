# ═══════════════════════════════════════════════════════════════════
# HookRelay — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyalayın ve değerleri girin:
#   cp deploy/env.production.example .env
#   nano .env
#
# Tüm servisler ücretsiz (free tier) katmanını kullanır.
# ═══════════════════════════════════════════════════════════════════

# ── Uygulama ──
APP_ENV=production
PORT=3000
RUST_LOG=info,hookrelay=info

# ── Güvenlik ──
# Her iki secret için güçlü, rastgele değerler kullanın:
#   openssl rand -hex 32
HMAC_SECRET=CHANGE_ME_TO_RANDOM_HEX_64_CHARS
JWT_SECRET=CHANGE_ME_TO_RANDOM_HEX_64_CHARS

# ── Webhook Ayarları ──
MAX_PAYLOAD_BYTES=1048576
RETENTION_DAYS=30
WEBHOOK_FORMAT=standard
WEBHOOK_TIMESTAMP_TOLERANCE_SECS=300

# ═══════════════════════════════════════════════════════════════════
# Veritabanı — Neon (PostgreSQL Cloud, Free Tier)
# ═══════════════════════════════════════════════════════════════════
# Kayıt: https://neon.tech
# Free Tier: 0.5 GB depolama, 24/7 compute
# Konsoldan connection string kopyalayın:
#   Dashboard > Connection Details > Connection string
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/hookrelay?sslmode=require

# ═══════════════════════════════════════════════════════════════════
# Redis — Upstash (Redis Cloud, Free Tier)
# ═══════════════════════════════════════════════════════════════════
# Kayıt: https://upstash.com
# Free Tier: 10,000 komut/gün, 256 MB depolama
# Konsoldan URL kopyalayın:
#   Dashboard > Database > Details > Redis URL
REDIS_URL=redis://default:xxx@yyy-xxx.upstash.io:6379

# ═══════════════════════════════════════════════════════════════════
# Observability — Grafana Cloud (Free Tier)
# ═══════════════════════════════════════════════════════════════════
# Kayıt: https://grafana.com
# Free Tier: 10K metrics, 50 GB logs, 50 GB traces
# OTLP endpoint bilgileri:
#   Grafana Cloud > My Account > OTLP > Details
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-xxx.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic_base64_encoded_credentials
OTEL_SERVICE_NAME=hookrelay

# ═══════════════════════════════════════════════════════════════════
# E-posta — Resend (Free Tier)
# ═══════════════════════════════════════════════════════════════════
# Kayıt: https://resend.com
# Free Tier: 3,000 e-posta/ay, 100 e-posta/gün
# API Key: Dashboard > API Keys > Create
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ═══════════════════════════════════════════════════════════════════
# Object Storage — Cloudflare R2 (Free Tier)
# ═══════════════════════════════════════════════════════════════════
# Kayıt: https://dash.cloudflare.com > R2 Object Storage
# Free Tier: 10 GB depolama, 10M okuma/yazma istek/ay
# Credentials: R2 > Manage R2 API Tokens > Create API Token
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=hookrelay-webhooks
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ═══════════════════════════════════════════════════════════════════
# Worker Ayarları
# ═══════════════════════════════════════════════════════════════════
MAX_ATTEMPTS=3
WORKER_CONCURRENCY=10

# ═══════════════════════════════════════════════════════════════════
# Opsiyonel: Dashboard (Vercel'de deploy edilecek)
# ═══════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/v1
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
