# ═════════════════════════════════════════════════════════════════════
# HookSniff — Production Environment Variables for GCP Cloud Run
# ═════════════════════════════════════════════════════════════════════
#
# SETUP INSTRUCTIONS:
#   1. Copy this file: cp deploy/env.production.example .env.production
#   2. Fill in ALL values marked with [REQUIRED]
#   3. For secrets (marked [SECRET]): Generate with: openssl rand -hex 32
#   4. Test locally: docker compose -f docker-compose.prod.yml up
#   5. Deploy: ./deploy/gcp-deploy.sh
#
# ═════════════════════════════════════════════════════════════════════

# ── APPLICATION ──
APP_ENV=production
PORT=3000
RUST_LOG=info,hooksniff=info
LOG_FORMAT=json

# ── SECURITY (REQUIRED) ──
# Generate secrets: openssl rand -hex 32
HMAC_SECRET=[REQUIRED - Generate with: openssl rand -hex 32]
JWT_SECRET=[REQUIRED - Generate with: openssl rand -hex 32]
ENCRYPTION_KEY=[REQUIRED - Generate with: openssl rand -hex 32]

# ── WEBHOOK SETTINGS ──
MAX_PAYLOAD_BYTES=1048576
RETENTION_DAYS=30
WEBHOOK_FORMAT=standard
WEBHOOK_TIMESTAMP_TOLERANCE_SECS=300

# ── CORS & URLs ──
CORS_ORIGINS=https://hooksniff.is-a.dev,https://www.hooksniff.is-a.dev
APP_URL=https://hooksniff.is-a.dev

# ═════════════════════════════════════════════════════════════════════
# DATABASE — Neon (PostgreSQL in Cloud) [REQUIRED]
# ═════════════════════════════════════════════════════════════════════
# Sign up: https://console.neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=[REQUIRED - Get from Neon dashboard]

# ═════════════════════════════════════════════════════════════════════
# CACHE — Upstash Redis (Serverless Redis) [REQUIRED]
# ═════════════════════════════════════════════════════════════════════
# Sign up: https://console.upstash.com
# Format: redis://default:password@host:port
REDIS_URL=[REQUIRED - Get from Upstash dashboard]
UPSTASH_REDIS_REST_URL=[OPTIONAL - For REST API]
UPSTASH_REDIS_REST_TOKEN=[OPTIONAL - For REST API]
RATE_LIMIT_STORE=redis

# ═════════════════════════════════════════════════════════════════════
# PAYMENT — Polar.sh (Global SaaS Payments) [REQUIRED]
# ═════════════════════════════════════════════════════════════════════
# Sign up: https://polar.sh
# Get tokens: https://dashboard.polar.sh/settings/tokens
POLAR_ACCESS_TOKEN=[REQUIRED - Get from Polar dashboard]
POLAR_WEBHOOK_SECRET=[REQUIRED - Generate in Polar webhooks]
POLAR_ENV=production
# Get product IDs from: https://dashboard.polar.sh/products
POLAR_PRODUCT_PRO=[REQUIRED - Your Polar Pro product ID]
POLAR_PRODUCT_BUSINESS=[REQUIRED - Your Polar Business product ID]

# ═════════════════════════════════════════════════════════════════════
# EMAIL — Resend (Transactional Email) [REQUIRED]
# ═════════════════════════════════════════════════════════════════════
# Sign up: https://resend.com
# API Key: https://resend.com/api-keys
RESEND_API_KEY=[REQUIRED - Get from Resend API keys]
NOTIFY_EMAIL=support@hooksniff.is-a.dev
NOTIFY_FROM_EMAIL=noreply@hooksniff.is-a.dev

# ═════════════════════════════════════════════════════════════════════
# OAUTH — Google & GitHub [OPTIONAL - For Social Login]
# ═════════════════════════════════════════════════════════════════════
# Google: https://console.cloud.google.com/apis/credentials
# GitHub: https://github.com/settings/apps
GOOGLE_CLIENT_ID=[OPTIONAL]
GOOGLE_CLIENT_SECRET=[OPTIONAL]
GITHUB_CLIENT_ID=[OPTIONAL]
GITHUB_CLIENT_SECRET=[OPTIONAL]

# ═════════════════════════════════════════════════════════════════════
# MONITORING — Sentry OpenTelemetry [OPTIONAL]
# ═════════════════════════════════════════════════════════════════════
# Sign up: https://sentry.io
# OTEL headers format: "Authorization: Bearer <token>"
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ═════════════════════════════════════════════════════════════════════
# STORAGE — Cloudflare R2 [OPTIONAL - For File Storage]
# ═════════════════════════════════════════════════════════════════════
# Sign up: https://www.cloudflare.com/en-gb/products/r2/
R2_ACCOUNT_ID=[OPTIONAL]
R2_ACCESS_KEY_ID=[OPTIONAL]
R2_SECRET_ACCESS_KEY=[OPTIONAL]
R2_BUCKET_NAME=hooksniff-storage
R2_ENDPOINT=[OPTIONAL]
