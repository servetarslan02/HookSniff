# ═══════════════════════════════════════════════════════════════════
# HookSniff — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp deploy/env.production.example .env
#   nano .env
# ═══════════════════════════════════════════════════════════════════

# ── Application ──
APP_ENV=production
PORT=3000
RUST_LOG=info,hooksniff=info

# ── Security (⚠️ Generate with: openssl rand -hex 32) ──
HMAC_SECRET=
JWT_SECRET=

# ── Webhook Settings ──
MAX_PAYLOAD_BYTES=1048576
RETENTION_DAYS=7
WEBHOOK_FORMAT=standard
WEBHOOK_TIMESTAMP_TOLERANCE_SECS=300

# ── CORS ──
CORS_ORIGINS=https://hooksniff.is-a.dev

# ── App URL (for checkout redirects) ──
APP_URL=https://hooksniff.is-a.dev

# ═══════════════════════════════════════════════════════════════════
# Database — Neon (PostgreSQL, Free Tier: 0.5 GB)
# ═══════════════════════════════════════════════════════════════════
DATABASE_URL=

# ═══════════════════════════════════════════════════════════════════
# Redis — Upstash (Free Tier: 256 MB)
# ═══════════════════════════════════════════════════════════════════
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_STORE=redis

# ═══════════════════════════════════════════════════════════════════
# Polar.sh — Payment Provider (Global)
# ═══════════════════════════════════════════════════════════════════
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_PRO=79fee3f9-04a2-46c1-804e-8ca7542b8119
POLAR_PRODUCT_BUSINESS=e5b7d88a-7606-4963-a070-4102ca6405e2
POLAR_ENV=production

# ═══════════════════════════════════════════════════════════════════
# iyzico — Payment Provider (Turkey)
# ═══════════════════════════════════════════════════════════════════
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_ENV=sandbox
IYZICO_PRICE_PRO=14900
IYZICO_PRICE_BUSINESS=44900

# ═══════════════════════════════════════════════════════════════════
# Email — Resend (Free Tier: 3K/month)
# ═══════════════════════════════════════════════════════════════════
RESEND_API_KEY=
NOTIFY_EMAIL=
NOTIFY_FROM_EMAIL=noreply@hooksniff.is-a.dev

# ═══════════════════════════════════════════════════════════════════
# Monitoring — Grafana Cloud (Free Tier)
# ═══════════════════════════════════════════════════════════════════
# OTel headers format: "Authorization: Bearer <instance_id>:<api_key>"
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ═══════════════════════════════════════════════════════════════════
# Storage — Cloudflare R2 (Free Tier: 10 GB)
# ═══════════════════════════════════════════════════════════════════
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hooksniff-storage
R2_ENDPOINT=

# ── Logging ──
LOG_FORMAT=json
