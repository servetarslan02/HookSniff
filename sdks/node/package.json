{
  "name": "hooksniff",
  "version": "1.0.0",
  "description": "Official HookSniff SDK — webhook delivery, verification, and management",
  "author": "HookSniff",
  "repository": "https://github.com/servetarslan02/HookSniff.git",
  "homepage": "https://hooksniff.com",
  "license": "MIT",
  "keywords": [
    "hooksniff",
    "webhooks",
    "api",
    "sdk",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "prepare": "npm run build",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "standardwebhooks": "1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
