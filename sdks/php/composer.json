{
    "name": "hooksniff/hooksniff-php",
    "description": "Official PHP client for HookSniff webhook delivery service",
    "type": "library",
    "version": "0.3.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Servet Arslan",
            "email": "support@hooksniff.dev",
            "homepage": "https://github.com/servetarslan02"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-curl": "*",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "OpenAPI\\Client\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenAPI\\Client\\Test\\": "test/"
        }
    },
    "keywords": ["webhooks", "hooksniff", "sdk", "delivery", "api"],
    "homepage": "https://github.com/servetarslan02/HookSniff",
    "support": {
        "issues": "https://github.com/servetarslan02/HookSniff/issues",
        "source": "https://github.com/servetarslan02/HookSniff"
    }
}
