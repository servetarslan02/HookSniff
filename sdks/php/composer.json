{
    "name": "hooksniff/hooksniff",
    "description": "Official PHP SDK for the HookSniff webhook delivery API",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "HookSniff\\": "src/"
        },
        "files": [
            "init.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "HookSniff\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-hash": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "authors": [
        {
            "name": "HookSniff",
            "email": "support@hooksniff.com"
        }
    ],
    "keywords": ["webhooks", "api", "sdk", "hooksniff"],
    "homepage": "https://hooksniff.com"
}
