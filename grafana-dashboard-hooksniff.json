{
  "dashboard": {
    "title": "HookSniff Performance",
    "tags": ["hooksniff", "webhooks", "performance"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "title": "API Health",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          { "expr": "hooksniff_api_healthy", "legendFormat": "Healthy" }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": { "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ] },
            "mappings": [
              { "type": "value", "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Healthy", "color": "green" } } }
            ]
          }
        }
      },
      {
        "title": "Success Rate (1h)",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          { "expr": "hooksniff_success_rate_1h", "legendFormat": "Success %" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent", "min": 0, "max": 100,
            "thresholds": { "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ] }
          }
        }
      },
      {
        "title": "Redis Cache Hit Rate",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          { "expr": "hooksniff_cache_hit_rate", "legendFormat": "Hit Rate %" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent", "min": 0, "max": 100,
            "thresholds": { "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ] }
          }
        }
      },
      {
        "title": "Active Connections",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          { "expr": "hooksniff_active_connections", "legendFormat": "Connections" }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": { "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ] }
          }
        }
      },
      {
        "title": "Deliveries (1h vs 24h)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          { "expr": "hooksniff_deliveries_1h", "legendFormat": "Total 1h" },
          { "expr": "hooksniff_delivered_1h", "legendFormat": "Delivered 1h" },
          { "expr": "hooksniff_failed_1h", "legendFormat": "Failed 1h" }
        ],
        "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } } }
      },
      {
        "title": "Queue Status",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          { "expr": "hooksniff_queue_pending", "legendFormat": "Pending" },
          { "expr": "hooksniff_queue_processing", "legendFormat": "Processing" },
          { "expr": "hooksniff_queue_delivered", "legendFormat": "Delivered" }
        ],
        "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } } }
      },
      {
        "title": "DB Latency (ms)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          { "expr": "hooksniff_db_latency_ms", "legendFormat": "DB Latency" }
        ],
        "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } } }
      },
      {
        "title": "Queue Latency (ms)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          { "expr": "hooksniff_queue_latency_ms", "legendFormat": "Queue Latency" }
        ],
        "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } } }
      },
      {
        "title": "Cache Hits vs Misses",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "targets": [
          { "expr": "hooksniff_cache_hits", "legendFormat": "Hits" },
          { "expr": "hooksniff_cache_misses", "legendFormat": "Misses" }
        ],
        "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } } }
      },
      {
        "title": "Rate Limited Requests (1h)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
        "targets": [
          { "expr": "hooksniff_rate_limited_1h", "legendFormat": "Rate Limited" }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": { "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ] }
          }
        }
      },
      {
        "title": "Failed Actions (1h)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
        "targets": [
          { "expr": "hooksniff_failed_actions_1h", "legendFormat": "Failed Actions" }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": { "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 50 }
            ] }
          }
        }
      },
      {
        "title": "Endpoints & Customers",
        "type": "stat",
        "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
        "targets": [
          { "expr": "hooksniff_endpoints_total", "legendFormat": "Total Endpoints" },
          { "expr": "hooksniff_customers_total", "legendFormat": "Total Customers" }
        ]
      },
      {
        "title": "New Signups (24h)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
        "targets": [
          { "expr": "hooksniff_customers_new_24h", "legendFormat": "New Customers" }
        ]
      },
      {
        "title": "Active Users (24h)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
        "targets": [
          { "expr": "hooksniff_active_users_24h", "legendFormat": "Active Users" }
        ]
      }
    ]
  }
}
