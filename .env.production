# ╔══════════════════════════════════════════════════════════════╗
# ║  HookRelay — Production Environment Configuration           ║
# ║  ⚠️  CHANGE ALL SECRETS BEFORE DEPLOYING                    ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Application ──
APP_ENV=production
PORT=3000
RUST_LOG=info,hookrelay=debug

# ── Database (PostgreSQL) ──
# Format: postgresql://user:password@host:port/dbname?sslmode=require
# Example: Neon, Supabase, or self-hosted PostgreSQL
DATABASE_URL=postgresql://hookrelay:CHANGE_ME@postgres:5432/hookrelay?sslmode=disable

# ── Security (⚠️ MUST SET BEFORE DEPLOYING) ──
# Used to sign webhook payloads (HMAC-SHA256)
# Generate with: openssl rand -hex 32
HMAC_SECRET=
# Used to sign JWT tokens for dashboard auth
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Rate Limiting ──
MAX_PAYLOAD_BYTES=1048576

# ── Worker ──
MAX_ATTEMPTS=3

# ── Queue ──
# PostgreSQL-based queue (uses webhook_queue table)
# No external queue service needed

# ── Data Retention ──
# Days to keep webhook delivery logs before automatic cleanup
RETENTION_DAYS=30

# ── AI Center (optional) ──
AI_CHECK_INTERVAL_SECS=30
AI_RISK_THRESHOLD_WARNING=60
AI_RISK_THRESHOLD_CRITICAL=80
AI_AUTO_FIX_ENABLED=true
AI_DEFENSE_ENABLED=true
AI_MAX_AUTO_ACTIONS_PER_HOUR=20

# ── AI Model API Keys (optional — at least one recommended) ──
MIMO_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# ── Notifications (optional) ──
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=
NOTIFY_EMAIL=admin@example.com
NOTIFY_EMAIL_FROM=ai@hookrelay.dev

# ── OpenTelemetry (optional) ──
# Set to "true" to enable distributed tracing
OTEL_ENABLED=false
# OTLP collector endpoint (gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# Log format: "pretty" (default) or "json"
LOG_FORMAT=json

# ── Stripe (optional — billing disabled if not set) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ── App URL (for Stripe redirects) ──
APP_URL=https://dashboard.hookrelay.io
