# ╔══════════════════════════════════════════════════════════════╗
# ║  HookRelay — Production Environment Configuration           ║
# ║  ⚠️  CHANGE ALL SECRETS BEFORE DEPLOYING                    ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Application ──
APP_ENV=production
PORT=3000
RUST_LOG=info,hookrelay=debug

# ── Database (CockroachDB) ──
# Format: postgresql://user@host:port/dbname?sslmode=disable
DATABASE_URL=postgresql://root@cockroachdb:26257/hookrelay?sslmode=disable

# ── Kafka / Redpanda ──
KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC=webhook-deliveries
KAFKA_CONSUMER_GROUP=hookrelay-worker

# ── Security (⚠️ MUST CHANGE) ──
# Used to sign webhook payloads (HMAC-SHA256)
HMAC_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
# Used to sign JWT tokens for dashboard auth
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# ── Rate Limiting ──
MAX_PAYLOAD_BYTES=1048576

# ── Worker ──
MAX_ATTEMPTS=3

# ── Temporal ──
TEMPORAL_URL=http://temporal:7233
TEMPORAL_TASK_QUEUE=hookrelay-deliveries

# ── Data Retention ──
# Days to keep webhook delivery logs before automatic cleanup
RETENTION_DAYS=30

# ── AI Center (optional) ──
AI_CHECK_INTERVAL_SECS=30
AI_RISK_THRESHOLD_WARNING=60
AI_RISK_THRESHOLD_CRITICAL=80
AI_AUTO_FIX_ENABLED=true
AI_DEFENSE_ENABLED=true
AI_MAX_AUTO_ACTIONS_PER_HOUR=20

# ── AI Model API Keys (optional — at least one recommended) ──
MIMO_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# ── Notifications (optional) ──
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=
NOTIFY_EMAIL=admin@example.com
NOTIFY_EMAIL_FROM=ai@hookrelay.dev

# ── OpenTelemetry (optional) ──
# Set to "true" to enable distributed tracing
OTEL_ENABLED=false
# OTLP collector endpoint (gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# Log format: "pretty" (default) or "json"
LOG_FORMAT=json
